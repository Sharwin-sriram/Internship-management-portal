{
	"info": {
		"_postman_id": "internship-portal-api",
		"name": "Internship Portal API",
		"description": "Complete API collection for testing the Internship Management Portal backend",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "Health & Status",
			"item": [
				{
					"name": "Health Check",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "http://localhost:9933/health",
							"protocol": "http",
							"host": ["localhost"],
							"port": "9933",
							"path": ["health"]
						},
						"description": "Check if the server is running"
					},
					"response": []
				},
				{
					"name": "API Test",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "http://localhost:9933/api/test",
							"protocol": "http",
							"host": ["localhost"],
							"port": "9933",
							"path": ["api", "test"]
						},
						"description": "Test endpoint showing available routes"
					},
					"response": []
				}
			]
		},
		{
			"name": "Password Reset",
			"item": [
				{
					"name": "Request Password Reset",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json",
								"type": "text"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"email\": \"test@example.com\"\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "http://localhost:9933/api/password-reset/request",
							"protocol": "http",
							"host": ["localhost"],
							"port": "9933",
							"path": ["api", "password-reset", "request"]
						},
						"description": "Request a password reset token for the given email"
					},
					"response": []
				},
				{
					"name": "Validate Reset Token",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"token\": \"your-reset-token-here\"\n}"
						},
						"url": {
							"raw": "http://localhost:9933/api/password-reset/validate",
							"protocol": "http",
							"host": ["localhost"],
							"port": "9933",
							"path": ["api", "password-reset", "validate"]
						},
						"description": "Validate if a reset token is valid and not expired"
					},
					"response": []
				},
				{
					"name": "Reset Password",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"token\": \"your-reset-token-here\",\n  \"newPassword\": \"NewPass@123\",\n  \"confirmPassword\": \"NewPass@123\"\n}"
						},
						"url": {
							"raw": "http://localhost:9933/api/password-reset/reset",
							"protocol": "http",
							"host": ["localhost"],
							"port": "9933",
							"path": ["api", "password-reset", "reset"]
						},
						"description": "Reset password using a valid token"
					},
					"response": []
				}
			]
		}
	],
	"variable": [
		{
			"key": "baseUrl",
			"value": "http://localhost:9933",
			"type": "string"
		}
	]
}
